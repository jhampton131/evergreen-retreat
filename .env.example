# EVERGREEN SUMMER — NETLIFY ENVIRONMENT VARIABLES
# Add these in: Netlify Dashboard → Site → Environment variables
# Never commit real keys to git — paste actual values directly in Netlify

# ── STRIPE ────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── EMAIL NOTIFICATIONS ───────────────────────────────
NOTIFICATION_EMAIL=your@email.com

# ── ZAPIER ────────────────────────────────────────────
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_HOOK_HERE
